{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "accessWidener": "example_mod.accesswidener",
  "name": "${mod_name}",
  "description": "${mod_desc}",
  "authors": [
    "${mod_author}"
  ],
  "contact": {
    "sources": "${mod_sources}"
  },
  "license": "${mod_license}",
  "icon": "assets/example_mod/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.example.example_mod.fabric.MainFabric"
    ],
    "modmenu": [
      "com.example.example_mod.fabric.config.gui.ModMenuIntegration"
    ]
  },
  "mixins": [
    "example_mod.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": "~${minecraft_version}",
    "java": ">=${java_version}"
  },
  "suggests": {
    "modmenu": ">=${mod_menu_version}"
  }
}